// AdCraft Academy — Prisma Schema
// Architecture: Modular Monolith (ADR-001)
// All tables include nullable orgId for future multi-tenancy
// Simulation state stored as JSON string

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & AUTH
// ============================================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  passwordHash  String?   // Nullable for OAuth-only; required for Credentials
  orgId         String?
  role          UserRole  @default(STUDENT)
  xp            Int       @default(0)
  level         Int       @default(1)
  streakDays    Int       @default(0)
  lastActiveAt  DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  enrollments   Enrollment[]
  progress      ModuleProgress[]
  toolSessions  ToolSession[]
  quizAttempts  QuizAttempt[]
  badges        UserBadge[]
  certificates  Certificate[]
  liveClassRegs LiveClassRegistration[]
  simulationAttempts SimulationAttempt[]
  teamMemberships    TeamMember[]
  eventLogs     EventLog[]
  mentorConversations MentorConversation[]

  @@index([orgId])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================================
// COURSE & CURRICULUM
// ============================================================================

model Course {
  id              String    @id @default(cuid())
  orgId           String?
  title           String
  slug            String    @unique
  description     String
  icon            String    @default("BookOpen")
  difficulty      CourseDifficulty @default(FOUNDATIONS)
  price           Float?    // Nullable — free courses
  tier            CourseTier? // Nullable — links to pricing tier
  estimatedHours  Int       @default(10)
  isPublished     Boolean   @default(false)
  sortOrder       Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  modules         Module[]
  enrollments     Enrollment[]
  liveClasses     LiveClass[]
  certificates    Certificate[]

  @@index([orgId])
  @@index([slug])
  @@index([isPublished])
}

model Module {
  id              String        @id @default(cuid())
  orgId           String?
  courseId        String
  moduleNumber    Int
  title           String
  slug            String        @unique
  description     String
  icon            String        @default("FileText")
  color           String        @default("orange")
  order           Int
  isPublished     Boolean       @default(false)
  estimatedMinutes Int          @default(30)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  course          Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons         Lesson[]
  progress        ModuleProgress[]
  simulations     Simulation[]
  resources       Resource[]

  @@unique([courseId, moduleNumber])
  @@index([orgId])
  @@index([courseId])
}

model Lesson {
  id              String    @id @default(cuid())
  orgId           String?
  moduleId        String
  lessonNumber    Int
  title           String
  slug            String    @unique
  content         String    // MDX content
  type            LessonType @default(READING)
  videoUrl        String?   // Optional video URL
  estimatedMinutes Int      @default(10)
  xpReward        Int       @default(50)
  isPublished     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  module          Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress        LessonProgress[]
  quiz            Quiz?

  @@unique([moduleId, lessonNumber])
  @@index([orgId])
  @@index([moduleId])
}

// ============================================================================
// ENROLLMENT & PROGRESS
// ============================================================================

model Enrollment {
  id              String    @id @default(cuid())
  orgId           String?
  userId          String
  courseId        String
  status          EnrollmentStatus @default(ACTIVE)
  enrolledAt      DateTime  @default(now())
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress        ModuleProgress[]

  @@unique([userId, courseId])
  @@index([orgId])
  @@index([userId])
  @@index([courseId])
  @@index([status])
}

model ModuleProgress {
  id              String            @id @default(cuid())
  orgId           String?
  userId          String
  moduleId        String
  enrollmentId    String?
  status          ProgressStatus    @default(NOT_STARTED)
  score           Int               @default(0) // 0-100
  xpEarned        Int               @default(0)
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  module          Module            @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  enrollment      Enrollment?       @relation(fields: [enrollmentId], references: [id])

  @@unique([userId, moduleId])
  @@index([orgId])
  @@index([userId])
  @@index([status])
}

model LessonProgress {
  id              String            @id @default(cuid())
  orgId           String?
  userId          String
  lessonId        String
  status          ProgressStatus    @default(NOT_STARTED)
  score           Int               @default(0) // 0-100
  xpEarned        Int               @default(0)
  timeSpentSeconds Int              @default(0)
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relations
  lesson          Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([orgId])
  @@index([userId])
  @@index([status])
}

// ============================================================================
// LIVE CLASSES
// ============================================================================

model LiveClass {
  id              String             @id @default(cuid())
  orgId           String?
  courseId        String
  title           String
  description     String
  instructorName  String             @default("Ryan Dabao")
  scheduledAt     DateTime
  durationMinutes Int                @default(60)
  meetingUrl      String?            // Zoom/Google Meet link
  recordingUrl    String?            // Post-class recording
  maxAttendees    Int                @default(50)
  isPublished     Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  // Relations
  course          Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  registrations   LiveClassRegistration[]

  @@index([orgId])
  @@index([courseId])
  @@index([scheduledAt])
}

model LiveClassRegistration {
  id              String             @id @default(cuid())
  liveClassId     String
  userId          String
  attended        Boolean            @default(false)
  registeredAt    DateTime           @default(now())
  createdAt       DateTime           @default(now())

  // Relations
  liveClass       LiveClass          @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([liveClassId, userId])
  @@index([liveClassId])
  @@index([userId])
}

// ============================================================================
// QUIZZES
// ============================================================================

model Quiz {
  id              String    @id @default(cuid())
  orgId           String?
  lessonId        String    @unique
  title           String
  description     String    @default("")
  passThreshold   Int       @default(70)
  timeLimitSeconds Int?
  isPublished     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  lesson          Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions       QuizQuestion[]
  attempts        QuizAttempt[]

  @@index([orgId])
  @@index([lessonId])
}

model QuizQuestion {
  id              String    @id @default(cuid())
  quizId          String
  order           Int
  question        String
  optionA         String
  optionB         String
  optionC         String
  optionD         String    @default("")
  correctAnswer   String    // "A" | "B" | "C" | "D"
  explanation     String    @default("")
  points          Int       @default(1)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  quiz            Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@unique([quizId, order])
}

model QuizAttempt {
  id              String        @id @default(cuid())
  orgId           String?
  userId          String
  quizId          String
  attemptNumber   Int
  status          AttemptStatus @default(IN_PROGRESS)
  answers         String        // JSON — { "1": "A", "2": "C", ... }
  score           Int           @default(0) // 0-100 percentage
  correctCount    Int           @default(0)
  totalQuestions  Int           @default(0)
  xpEarned        Int           @default(0)
  timeSpentSeconds Int          @default(0)
  startedAt       DateTime      @default(now())
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz            Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId, attemptNumber])
  @@index([orgId])
  @@index([userId])
  @@index([quizId])
  @@index([status])
}

// ============================================================================
// ACHIEVEMENTS: BADGES & CERTIFICATES
// ============================================================================

model Badge {
  id          String        @id @default(cuid())
  orgId       String?
  slug        String        @unique
  title       String
  description String
  icon        String
  category    BadgeCategory
  tier        BadgeTier     @default(BRONZE)
  xpReward    Int           @default(0)
  criteria    String        // JSON — criteria for programmatic awarding
  order       Int           @default(0)
  isSecret    Boolean       @default(false)
  isPublished Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  awards      UserBadge[]

  @@index([orgId])
  @@index([category])
  @@index([tier])
}

model UserBadge {
  id          String    @id @default(cuid())
  orgId       String?
  userId      String
  badgeId     String
  xpEarned    Int       @default(0)
  earnedAt    DateTime  @default(now())
  createdAt   DateTime  @default(now())

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge       Badge     @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([orgId])
  @@index([userId])
  @@index([badgeId])
  @@index([earnedAt])
}

model Certificate {
  id              String   @id @default(cuid())
  orgId           String?
  userId          String
  courseId        String
  title           String   @default("AdCraft PPC Command Center")
  status          String   @default("active") // "active" | "expired" | "revoked"
  verificationHash String  @unique
  metadata        String?  // JSONB
  issuedAt        DateTime @default(now())
  expiresAt       DateTime?
  revokedAt       DateTime?
  revokedReason   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course          Course   @relation(fields: [courseId], references: [id])

  @@index([userId])
  @@index([verificationHash])
  @@index([status])
  @@index([courseId])
}

// ============================================================================
// INTERACTIVE TOOLS
// ============================================================================

model ToolSession {
  id              String        @id @default(cuid())
  orgId           String?
  userId          String
  toolType        ToolType
  scenarioId      String?       // Reference to the scenario/fixture used
  status          AttemptStatus @default(IN_PROGRESS)
  state           String        // JSON — full session state
  score           Int           @default(0) // 0-100
  timeSpentSeconds Int          @default(0)
  startedAt       DateTime      @default(now())
  submittedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  results         ToolResult[]

  @@index([orgId])
  @@index([userId])
  @@index([toolType])
  @@index([status])
}

model ToolResult {
  id              String        @id @default(cuid())
  orgId           String?
  sessionId       String
  step            Int           // Step/round number within the session
  prompt          String        // What was asked
  decision        String        // User's selected option
  correct         String        // Correct option
  isCorrect       Boolean
  explanation     String        // Why this answer was right/wrong
  pointsEarned    Int           @default(0)
  createdAt       DateTime      @default(now())

  // Relations
  session         ToolSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([isCorrect])
}

// Legacy simulation models (kept for backward compatibility)
model Simulation {
  id              String              @id @default(cuid())
  orgId           String?
  moduleId        String
  type            SimulationType
  title           String
  slug            String              @unique
  description     String
  difficulty      SimulationDifficulty @default(INTERMEDIATE)
  timeLimitSeconds Int?
  xpReward        Int                 @default(200)
  isPublished     Boolean             @default(false)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relations
  module          Module              @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  attempts        SimulationAttempt[]

  @@index([orgId])
  @@index([type])
}

model SimulationAttempt {
  id              String              @id @default(cuid())
  orgId           String?
  userId          String
  simulationId    String
  attemptNumber   Int
  status          AttemptStatus       @default(IN_PROGRESS)
  previewScore    Int                 @default(0)
  officialScore   Int?
  scoreDiscrepancy Boolean            @default(false)
  state           String              // JSON
  actions         String              // JSON
  timeSpentSeconds Int                @default(0)
  startedAt       DateTime            @default(now())
  submittedAt     DateTime?
  gradedAt        DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  // Relations
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  simulation      Simulation          @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  @@unique([userId, simulationId, attemptNumber])
  @@index([orgId])
  @@index([userId])
  @@index([simulationId])
  @@index([status])
}

// ============================================================================
// RESOURCES (downloadable learning materials)
// ============================================================================

model Resource {
  id          String          @id @default(cuid())
  orgId       String?
  moduleId    String?
  title       String
  description String          @default("")
  type        ResourceType
  fileUrl     String
  fileSize    Int?            // Bytes
  isPublished Boolean         @default(false)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  module      Module?         @relation(fields: [moduleId], references: [id])

  @@index([orgId])
  @@index([moduleId])
  @@index([type])
  @@index([isPublished])
}

// ============================================================================
// SEARCH TERM DATA (STR Triage Arena)
// ============================================================================

model SearchTermRecord {
  id              String    @id @default(cuid())
  orgId           String?
  datasetId       String
  searchTerm      String
  keyword         String
  matchType       MatchType
  impressions     Int
  clicks          Int
  ctr             Float
  spend           Float
  cpc             Float
  orders          Int
  unitsSold       Int
  sales           Float
  acos            Float
  roas            Float
  recommendedAction String
  reasoning       String
  createdAt       DateTime  @default(now())

  @@index([orgId])
  @@index([datasetId])
  @@index([searchTerm])
}

// ============================================================================
// CAMPAIGN TEMPLATES (Campaign Builder)
// ============================================================================

model CampaignTemplate {
  id              String              @id @default(cuid())
  orgId           String?
  name            String
  type            CampaignType        @default(SPONSORED_PRODUCTS)
  targetingType   TargetingType       @default(MANUAL)
  dailyBudget     Float               @default(0)
  bidStrategy     BidStrategy         @default(LEGACY)
  defaultBid      Float               @default(1.0)
  structure       String              // JSON
  isCorrect       Boolean             @default(false)
  explanation     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([orgId])
  @@index([type])
}

// ============================================================================
// ORGANIZATION & TEAM (future multi-tenant)
// ============================================================================

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  settings  String?  // JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   TeamMember[]

  @@index([slug])
}

model TeamMember {
  id        String       @id @default(cuid())
  orgId     String
  userId    String
  role      TeamRole     @default(MEMBER)
  joinedAt  DateTime     @default(now())
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([orgId])
  @@index([userId])
}

// ============================================================================
// EVENT LOGGING & XP MULTIPLIERS
// ============================================================================

model XpMultiplier {
  id        String   @id @default(cuid())
  name      String
  multiplier Float   @default(2.0)
  startsAt  DateTime
  endsAt    DateTime
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([active, startsAt, endsAt])
}

model EventLog {
  id        String   @id @default(cuid())
  userId    String
  eventType String
  metadata  String?  // JSON
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([eventType])
}

// ============================================================================
// AI MENTOR
// ============================================================================

model MentorConversation {
  id        String          @id @default(cuid())
  userId    String
  title     String          @default("New conversation")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  MentorMessage[]

  @@index([userId, updatedAt])
}

model MentorMessage {
  id             String             @id @default(cuid())
  conversationId String
  role           MentorMessageRole
  content        String
  createdAt      DateTime           @default(now())

  conversation   MentorConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum MentorMessageRole {
  USER
  ASSISTANT
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum CourseDifficulty {
  FOUNDATIONS
  INTERMEDIATE
  ADVANCED
  MASTERY
}

enum CourseTier {
  PPC_FOUNDATIONS
  ACCELERATED_MASTERY
  ULTIMATE_TRANSFORMATION
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum LessonType {
  READING
  SIMULATION
  QUIZ
  VIDEO
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum SimulationType {
  CAMPAIGN_BUILDER
  BID_ELEVATOR
  STR_TRIAGE_ARENA
}

enum SimulationDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  GRADED
  ARCHIVED
}

enum MatchType {
  BROAD
  PHRASE
  EXACT
}

enum CampaignType {
  SPONSORED_PRODUCTS
  SPONSORED_BRANDS
  SPONSORED_DISPLAY
}

enum TargetingType {
  MANUAL
  AUTO
}

enum BidStrategy {
  LEGACY
  DYNAMIC_UP_ONLY
  DYNAMIC_UP_DOWN
}

enum BadgeCategory {
  ENGAGEMENT
  MASTERY
  XP_MILESTONE
  STREAK
  SOCIAL
}

enum BadgeTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum ResourceType {
  PDF
  SPREADSHEET
  TEMPLATE
  CHEAT_SHEET
  VIDEO
  LINK
  OTHER
}

enum ToolType {
  CAMPAIGN_BUILDER
  BID_ELEVATOR
  STR_TRIAGE
}

enum TeamRole {
  OWNER
  MANAGER
  INSTRUCTOR
  MEMBER
}
